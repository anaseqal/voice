# SQLite path (file: prefix). Use absolute path in production.
DATABASE_URL="file:./data/voice.db"

# Single-user auth
AUTH_USERNAME="admin"
# Generate hash:  bun run lib/hash.ts 'your-password'
# Then BASE64-encode it:  echo -n '<the-hash>' | base64
# (Required because @next/env interpolates `$` chars in bcrypt hashes.)
AUTH_PASSWORD_HASH="base64-encoded-bcrypt-hash"
# Random 32+ char string used to encrypt session cookies
SESSION_PASSWORD="replace-with-32-or-more-random-chars-or-cookie-fails"

# RunPod worker
WORKER_BASE_URL="https://your-pod-id-8000.proxy.runpod.net"
WORKER_BEARER_TOKEN="paste-the-same-token-set-on-the-pod"

# Public origin used for callback URLs sent to the worker.
# In production set to https://voice.ihub2.com
PUBLIC_BASE_URL="http://localhost:3000"

# Token the worker uses when calling our callback endpoints
CALLBACK_BEARER_TOKEN="separate-random-string-for-callbacks"

# Where uploads/outputs/avatars live on disk
STORAGE_DIR="./data/storage"
